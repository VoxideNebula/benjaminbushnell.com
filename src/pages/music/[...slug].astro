---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map(album => ({
    params: { slug: album.id },
    props: { album }
  }));
}

const { album } = Astro.props;
const { Content } = await render(album);
---

<Base pageTitle={album.data.title}>
  <div class="min-h-screen bg-black pt-24">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <a href="/music" class="text-purple-400 hover:text-purple-300 mb-6 inline-block">← Back to Music</a>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class="sticky top-24">
          <Image 
            src={album.data.coverImage} 
            alt={album.data.title}
            width={600}
            height={600}
            class="w-full rounded-2xl shadow-2xl border border-white/10"
          />
          
          <div class="mt-8 space-y-4">
            {album.data.spotify && (
              <a href={album.data.spotify} target="_blank" class="block w-full py-3 px-6 bg-[#1DB954] hover:bg-[#1ed760] text-white rounded-lg font-medium text-center transition-colors">
                Listen on Spotify
              </a>
            )}
            {album.data.appleMusic && (
              <a href={album.data.appleMusic} target="_blank" class="block w-full py-3 px-6 bg-[#FA243C] hover:bg-[#ff2d47] text-white rounded-lg font-medium text-center transition-colors">
                Listen on Apple Music
              </a>
            )}
            {album.data.soundcloud && (
              <a href={album.data.soundcloud} target="_blank" class="block w-full py-3 px-6 bg-[#FF5500] hover:bg-[#ff6a1a] text-white rounded-lg font-medium text-center transition-colors">
                Listen on SoundCloud
              </a>
            )}
            {album.data.youtube && (
              <a href={album.data.youtube} target="_blank" class="block w-full py-3 px-6 bg-[#FF0000] hover:bg-[#ff1a1a] text-white rounded-lg font-medium text-center transition-colors">
                Watch on YouTube
              </a>
            )}
          </div>
        </div>

        <div class="prose prose-invert max-w-none">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">{album.data.title}</h1>
          <p class="text-xl text-gray-400 mb-6">{album.data.artist}</p>
          <p class="text-gray-500 mb-8">Released: {album.data.releaseDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          
          {album.data.description && (
            <p class="text-gray-300 text-lg mb-8">{album.data.description}</p>
          )}
          
          <div class="text-gray-300 prose prose-invert">
            <Content />
          </div>

          {album.data.tracks && album.data.tracks.length > 0 && (
            <div class="mt-12">
              <h2 class="text-2xl font-bold text-white mb-4">Tracklist</h2>
              <div class="space-y-2">
                {album.data.tracks.map((track, index) => (
                  <div class="flex justify-between items-center p-3 bg-white/5 rounded-lg border border-white/10">
                    <span class="text-gray-300">
                      <span class="text-gray-500 mr-3">{index + 1}.</span>
                      {track.title}
                    </span>
                    <span class="text-gray-500">{track.duration}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Base>
