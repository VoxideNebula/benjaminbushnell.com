---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base pageTitle={project.data.title}>
  <div class="min-h-screen bg-black pt-24">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <a href="/projects" class="text-purple-400 hover:text-purple-300 mb-6 inline-block">← Back to Projects</a>
      
      <div class="mb-12">
        <Image 
          src={project.data.image} 
          alt={project.data.title}
          width={1200}
          height={675}
          class="w-full aspect-video object-cover rounded-2xl shadow-2xl border border-white/10 mb-8"
        />
        
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{project.data.title}</h1>
        <p class="text-xl text-gray-300 mb-6">{project.data.description}</p>
        
        <div class="flex flex-wrap gap-2 mb-8">
          {project.data.tags.map((tag) => (
            <span class="px-3 py-1 text-xs font-semibold bg-purple-500/20 text-purple-300 rounded-full border border-purple-500/30">
              {tag}
            </span>
          ))}
        </div>

        <div class="flex gap-4">
          {project.data.github && (
            <a href={project.data.github} target="_blank" class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg font-medium transition-colors">
              View on GitHub
            </a>
          )}
          {project.data.demo && (
            <a href={project.data.demo} target="_blank" class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
              Live Demo
            </a>
          )}
        </div>
      </div>

      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>
</Base>
