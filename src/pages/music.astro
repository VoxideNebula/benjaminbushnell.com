---
import Base from '../layouts/Base.astro';
import AlbumCard from '../components/AlbumCard.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const albums = await getCollection('albums');
const sortedAlbums = albums.sort((a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime());
---

<Base pageTitle="Music">
  <PageHero 
    title="Music" 
    subtitle="Electronic music productions and releases"
  />

  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedAlbums.map((album, index) => (
        <AlbumCard
          title={album.data.title}
          artist={album.data.artist}
          coverImage={album.data.coverImage}
          spotify={album.data.spotify}
          appleMusic={album.data.appleMusic}
          soundcloud={album.data.soundcloud}
          youtube={album.data.youtube}
          slug={album.id}
          loading={index < 3 ? "eager" : "lazy"}
        />
      ))}
    </div>
  </div>
</Base>
