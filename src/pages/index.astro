---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import AlbumCard from '../components/AlbumCard.astro';
import BlogCard from '../components/BlogCard.astro';
import ArtCard from '../components/ArtCard.astro';
import AboutMe from '../components/AboutMe.astro';
import Hero from '../components/Hero.astro';

const pageTitle = 'Home';

// Get featured content
const projects = await getCollection('projects');
const featuredProjects = projects.filter(p => p.data.featured).sort((a, b) => a.data.order - b.data.order).slice(0, 3);

const albums = await getCollection('albums');
const featuredAlbums = albums.filter(a => a.data.featured).sort((a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime()).slice(0, 3);

const blog = await getCollection('blog');
const recentPosts = blog.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);

const art = await getCollection('art');
const featuredArt = art.filter(a => a.data.featured).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 4);
---

<Base pageTitle={pageTitle}>
  <!-- Hero Section -->
  <Hero />

  <!-- About Section -->
  <AboutMe />

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="py-24 bg-slate-900">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-center mb-12">
          <div>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Featured Projects</h2>
            <p class="text-gray-400 text-lg">Recent work in cloud infrastructure and automation</p>
          </div>
          <a href="/projects" class="hidden md:inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View All →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              image={project.data.image}
              tags={project.data.tags}
              github={project.data.github}
              demo={project.data.demo}
              slug={project.id}
            />
          ))}
        </div>

        <div class="text-center mt-12 md:hidden">
          <a href="/projects" class="inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View All Projects →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Featured Music -->
  {featuredAlbums.length > 0 && (
    <section class="py-24 bg-gradient-to-b from-slate-900 to-black">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-center mb-12">
          <div>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Latest Music</h2>
            <p class="text-gray-400 text-lg">Electronic music productions and releases</p>
          </div>
          <a href="/music" class="hidden md:inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View All →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredAlbums.map((album) => (
            <AlbumCard
              title={album.data.title}
              artist={album.data.artist}
              coverImage={album.data.coverImage}
              spotify={album.data.spotify}
              appleMusic={album.data.appleMusic}
              soundcloud={album.data.soundcloud}
              youtube={album.data.youtube}
              slug={album.id}
            />
          ))}
        </div>

        <div class="text-center mt-12 md:hidden">
          <a href="/music" class="inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View All Music →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Featured Art -->
  {featuredArt.length > 0 && (
    <section class="py-24 bg-black">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-center mb-12">
          <div>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Art & Photography</h2>
            <p class="text-gray-400 text-lg">Visual creations and photographic works</p>
          </div>
          <a href="/art" class="hidden md:inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View Gallery →
          </a>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {featuredArt.map((artwork) => (
            <ArtCard
              title={artwork.data.title}
              image={artwork.data.image}
              category={artwork.data.category}
              slug={artwork.id}
            />
          ))}
        </div>

        <div class="text-center mt-12 md:hidden">
          <a href="/art" class="inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View Gallery →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Recent Blog Posts -->
  {recentPosts.length > 0 && (
    <section class="py-24 bg-gradient-to-b from-black to-slate-900">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-center mb-12">
          <div>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Latest Posts</h2>
            <p class="text-gray-400 text-lg">Thoughts on technology, creativity, and more</p>
          </div>
          <a href="/blog/1" class="hidden md:inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View Blog →
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {recentPosts.map((post) => (
            <BlogCard
              url={`/posts/${post.id}`}
              title={post.data.title}
              imageUrl={post.data.image.url}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              content={post.body}
            />
          ))}
        </div>

        <div class="text-center mt-12 md:hidden">
          <a href="/blog/1" class="inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
            View All Posts →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-purple-900/30 via-slate-900 to-black">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Let's Connect</h2>
      <p class="text-xl text-gray-300 mb-12">
        Interested in collaborating or just want to say hello? Feel free to reach out.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:contact@benjaminbushnell.com" class="px-8 py-4 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-all transform hover:scale-105">
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</Base>
