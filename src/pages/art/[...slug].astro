---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const artAlbums = await getCollection('artAlbums');
  return artAlbums.map(album => ({
    params: { slug: album.id },
    props: { album }
  }));
}

const { album } = Astro.props;
const { Content } = await render(album);
---

<Base pageTitle={album.data.title}>
  <div class="min-h-screen bg-black pt-24">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <a href="/art" class="text-purple-400 hover:text-purple-300 mb-6 inline-block">← Back to Art Gallery</a>
      
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{album.data.title}</h1>
        <div class="flex gap-4 text-gray-400 mb-4">
          <span class="capitalize">{album.data.category}</span>
          <span>•</span>
          <span>{album.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        <p class="text-xl text-gray-300 mb-6">{album.data.description}</p>
        
        {album.data.tags && (
          <div class="flex flex-wrap gap-2 mb-8">
            {album.data.tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold bg-purple-500/20 text-purple-300 rounded-full border border-purple-500/30">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <div class="prose prose-invert max-w-none mb-12">
        <Content />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {album.data.artworks.map((artwork) => (
          <div class="group relative bg-gradient-to-br from-white/5 to-white/10 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-white/30 hover:shadow-2xl hover:shadow-purple-500/20">
            <div class="aspect-square w-full overflow-hidden bg-black/40">
              <Image 
                src={artwork.image} 
                alt={artwork.title || album.data.title}
                width={600}
                height={600}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
            </div>
            {(artwork.title || artwork.description) && (
              <div class="p-4">
                {artwork.title && (
                  <h3 class="text-lg font-bold text-white mb-1">{artwork.title}</h3>
                )}
                {artwork.description && (
                  <p class="text-sm text-gray-400">{artwork.description}</p>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>
