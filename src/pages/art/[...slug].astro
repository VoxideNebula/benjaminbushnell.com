---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const artworks = await getCollection('art');
  return artworks.map(art => ({
    params: { slug: art.id },
    props: { art }
  }));
}

const { art } = Astro.props;
const { Content } = await render(art);
---

<Base pageTitle={art.data.title}>
  <div class="min-h-screen bg-black pt-24">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <a href="/art" class="text-purple-400 hover:text-purple-300 mb-6 inline-block">← Back to Art Gallery</a>
      
      <div class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{art.data.title}</h1>
        <div class="flex gap-4 text-gray-400">
          <span class="capitalize">{art.data.category}</span>
          <span>•</span>
          <span>{art.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        {art.data.tags && (
          <div class="flex flex-wrap gap-2 mt-4">
            {art.data.tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold bg-purple-500/20 text-purple-300 rounded-full border border-purple-500/30">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <div class="mb-12">
        <Image 
          src={art.data.image} 
          alt={art.data.title}
          width={1200}
          height={1200}
          class="w-full rounded-2xl shadow-2xl border border-white/10"
        />
      </div>

      {art.data.description && (
        <div class="prose prose-invert max-w-none">
          <p class="text-lg text-gray-300">{art.data.description}</p>
        </div>
      )}
      
      <div class="prose prose-invert max-w-none mt-8">
        <Content />
      </div>
    </div>
  </div>
</Base>
