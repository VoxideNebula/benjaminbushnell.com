---
import Base from '../layouts/Base.astro';
import BookCard from '../components/BookCard.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const sortedBooks = books.sort((a, b) => {
  if (!a.data.publishDate) return 1;
  if (!b.data.publishDate) return -1;
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});
---

<Base pageTitle="Books & Writings">
  <PageHero 
    title="Books & Writings"
    subtitle="Published works and upcoming releases"
  >
    <a href="https://books.benjaminbushnell.com" target="_blank" class="inline-block mt-6 px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-colors">
      Visit Books Website →
    </a>
  </PageHero>

  <div class="max-w-5xl mx-auto px-6 py-16">
    <div class="space-y-8">
      {sortedBooks.map((book, index) => (
        <BookCard
          title={book.data.title}
          subtitle={book.data.subtitle}
          coverImage={book.data.coverImage}
          status={book.data.status}
          externalLink={book.data.externalLink}
          slug={book.id}
          loading={index < 2 ? "eager" : "lazy"}
        >
          <p class="text-gray-300">{book.data.description}</p>
        </BookCard>
      ))}
    </div>
  </div>
</Base>
