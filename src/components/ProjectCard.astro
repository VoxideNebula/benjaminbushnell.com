---
import { Image } from 'astro:assets';

const { title, description, image, tags, github, demo, slug, loading = "lazy" } = Astro.props;
---

<div class="group relative bg-gradient-to-br from-white/5 to-white/10 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-white/30 hover:shadow-2xl hover:shadow-purple-500/20">
  <a href={`/projects/${slug}`} class="block aspect-video w-full overflow-hidden bg-black/40">
    <Image 
      src={image} 
      alt={title}
      width={800}
      height={450}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
  </a>
  
  <div class="p-6">
    <a href={`/projects/${slug}`}>
      <h3 class="text-2xl font-bold text-white mb-2 hover:text-purple-400 transition-colors">{title}</h3>
    </a>
    <p class="text-gray-300 mb-4 line-clamp-2">{description}</p>
    
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag: string) => (
        <span class="px-3 py-1 text-xs font-semibold bg-purple-500/20 text-purple-300 rounded-full border border-purple-500/30">
          {tag}
        </span>
      ))}
    </div>
    
    <div class="flex gap-3">
      {github && (
        <a href={github} target="_blank" class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg text-sm font-medium transition-colors">
          GitHub
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg text-sm font-medium transition-colors">
          Live Demo
        </a>
      )}
    </div>
  </div>
</div>
