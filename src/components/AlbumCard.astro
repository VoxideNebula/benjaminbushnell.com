---
import { Image } from 'astro:assets';

const { title, artist, coverImage, spotify, appleMusic, soundcloud, youtube, slug, loading = "lazy" } = Astro.props;
---

<div class="group relative bg-gradient-to-br from-white/5 to-white/10 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-white/30 hover:shadow-2xl hover:shadow-purple-500/20">
  <a href={`/music/${slug}`} class="block aspect-square w-full overflow-hidden bg-black/40">
    <Image 
      src={coverImage} 
      alt={title}
      width={400}
      height={400}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
    />
  </a>
  
  <div class="p-6">
    <a href={`/music/${slug}`}>
      <h3 class="text-2xl font-bold text-white mb-2 hover:text-purple-400 transition-colors">{title}</h3>
    </a>
    <p class="text-gray-300 mb-4">{artist}</p>
    
    <div class="flex flex-wrap gap-2">
      {spotify && (
        <a href={spotify} target="_blank" class="px-4 py-2 bg-[#1DB954] hover:bg-[#1ed760] text-white rounded-lg text-sm font-medium transition-colors">
          Spotify
        </a>
      )}
      {appleMusic && (
        <a href={appleMusic} target="_blank" class="px-4 py-2 bg-[#FA243C] hover:bg-[#ff2d47] text-white rounded-lg text-sm font-medium transition-colors">
          Apple Music
        </a>
      )}
      {soundcloud && (
        <a href={soundcloud} target="_blank" class="px-4 py-2 bg-[#FF5500] hover:bg-[#ff6a1a] text-white rounded-lg text-sm font-medium transition-colors">
          SoundCloud
        </a>
      )}
      {youtube && (
        <a href={youtube} target="_blank" class="px-4 py-2 bg-[#FF0000] hover:bg-[#ff1a1a] text-white rounded-lg text-sm font-medium transition-colors">
          YouTube
        </a>
      )}
    </div>
  </div>
</div>
