---
import { Image } from 'astro:assets';

const { title, image, category, slug, loading = "lazy" } = Astro.props;
---

<div class="group relative bg-gradient-to-br from-white/5 to-white/10 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-white/30 hover:shadow-2xl hover:shadow-purple-500/20">
  <a href={`/art/${slug}`} class="block aspect-square w-full overflow-hidden bg-black/40">
    <Image 
      src={image} 
      alt={title}
      width={600}
      height={600}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
  </a>
  
  <div class="p-6">
    <a href={`/art/${slug}`}>
      <h3 class="text-2xl font-bold text-white mb-2 hover:text-purple-400 transition-colors">{title}</h3>
    </a>
    <p class="text-gray-300 mb-4 capitalize">{category}</p>
  </div>
</div>
