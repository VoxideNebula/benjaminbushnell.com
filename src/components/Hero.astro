---
import { Image } from 'astro:assets';
---

<section class="relative min-h-screen w-full flex items-center justify-center overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-center bg-fixed"
    style="background-image: url('/hero-background.jpeg');"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black"></div>
  </div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-6 py-32 text-center">
    <div class="mb-8">
      <Image 
        src="/profile.jpeg" 
        alt="Benjamin Bushnell"
        width={192}
        height={192}
        loading="eager"
        class="w-48 h-48 rounded-full mx-auto object-cover border-4 border-purple-500/50 shadow-2xl shadow-purple-500/30"
      />
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
      Benjamin Bushnell
    </h1>
    
    <p class="text-xl md:text-2xl text-gray-300 mb-4 max-w-3xl mx-auto">
      Cloud DevOps Engineer • Music Producer • Writer • Artist
    </p>
    
    <p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
      Building elegant solutions in the cloud, creating electronic music, and exploring the intersection of technology and creativity
    </p>
    
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/projects" class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-medium transition-all transform hover:scale-105">
        View Projects
      </a>
      <a href="/music" class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg font-medium transition-all backdrop-blur-sm">
        Listen to Music
      </a>
      <a href="/blog/1" class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg font-medium transition-all backdrop-blur-sm">
        Read Blog
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
