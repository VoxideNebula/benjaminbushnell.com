---
import { Image } from 'astro:assets';

const { title, subtitle, coverImage, status, externalLink, slug, loading = "lazy" } = Astro.props;

const statusColors = {
  published: 'bg-green-500/20 text-green-300 border-green-500/30',
  upcoming: 'bg-yellow-500/20 text-yellow-300 border-yellow-500/30',
  draft: 'bg-gray-500/20 text-gray-300 border-gray-500/30'
};
---

<div class="group relative bg-gradient-to-br from-white/5 to-white/10 border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-white/30 hover:shadow-2xl hover:shadow-purple-500/20">
  <a href={externalLink || `/books/${slug}`} target={externalLink ? "_blank" : undefined} class="block aspect-[2/3] w-full overflow-hidden bg-black/40">
    <Image 
      src={coverImage} 
      alt={title}
      width={300}
      height={450}
      loading={loading}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
  </a>
  
  <div class="p-6">
    <a href={externalLink || `/books/${slug}`} target={externalLink ? "_blank" : undefined}>
      <h3 class="text-2xl font-bold text-white mb-2 hover:text-purple-400 transition-colors">{title}</h3>
    </a>
    {subtitle && <p class="text-gray-400 italic mb-2">{subtitle}</p>}
    
    <div class="mb-4">
      <span class={`inline-block px-3 py-1 text-xs font-semibold rounded-full border ${statusColors[status]} capitalize`}>
        {status}
      </span>
    </div>
    
    <slot />
    
    <div class="flex gap-3 mt-4">
      {externalLink && status === 'published' && (
        <a href={externalLink} target="_blank" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg text-sm font-medium transition-colors">
          Read Now
        </a>
      )}
    </div>
  </div>
</div>
